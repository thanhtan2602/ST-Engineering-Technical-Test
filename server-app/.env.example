# Copy to `.env` (git-ignored) or export in your shell.
# ASP.NET Core also reads these as `ConnectionStrings__Database` etc. — the double underscore maps to the nested JSON key.

# ─────────────────────────────────────────────────────────────
# Standard ASP.NET Core
# ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# Kestrel URLs (only needed when running outside Docker; Docker Compose maps 8080 → host 5005)
# ASPNETCORE_URLS=http://localhost:5005;https://localhost:5050

# ─────────────────────────────────────────────────────────────
# Database — Postgres 17
# ─────────────────────────────────────────────────────────────
# Local host (docker compose up -d fashionshopdb → host port 5434):
ConnectionStrings__Database=Server=localhost;Port=5434;Database=FashionShopDb;User Id=postgres;Password=postgres;Include Error Detail=true

# Inside Docker Compose (see docker-compose.override.yml):
# ConnectionStrings__Database=Server=fashionshopdb;Port=5432;Database=FashionShopDb;User Id=postgres;Password=postgres;Include Error Detail=true

# ─────────────────────────────────────────────────────────────
# Redis (optional — leave empty to force in-memory cache)
# ─────────────────────────────────────────────────────────────
ConnectionStrings__Redis=localhost:6380
# Inside Docker Compose:
# ConnectionStrings__Redis=cacheredis:6379

# ─────────────────────────────────────────────────────────────
# Uploads (documented — currently hardcoded to wwwroot/uploads)
# ─────────────────────────────────────────────────────────────
# Uploads__RootPath=wwwroot/uploads
# Uploads__PublicBaseUrl=/uploads
