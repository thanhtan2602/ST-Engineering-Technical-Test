{
  "info": {
    "name": "FashionShop Catalog API",
    "_postman_id": "fashionshop-catalog-v2",
    "description": "Complete CRUD for the FashionShop Catalog module.\n\n**Base URL**\n- Docker:    `http://localhost:5005/api/v1`\n- Local dev: `http://localhost:5000/api/v1`\n\nSwagger UI: `{host}/swagger/index.html`\n\n---\n**Full demo flow (use _Guided Demo Flow folder)**\n1. GET Fashion ProductType → verify seed\n2. GET All Products → see seeded list\n3. GET Adidas (captures ETag)\n4. PUT with correct ETag → 200 OK\n5. PUT with same (now stale) ETag → 409 Conflict\n6. PATCH status → Inactive\n7. POST attribute upsert → update color\n8. CREATE new product\n9. UPLOAD image to new product\n10. DELETE new product → soft delete\n11. GET deleted product → 404",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:5005/api/v1", "type": "string",
      "description": "Docker port 5005. For local dotnet run use http://localhost:5000/api/v1" },
    { "key": "categoryId",       "value": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaab", "type": "string", "description": "Shoes (seeded)" },
    { "key": "brandId",          "value": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb", "type": "string", "description": "Nike (seeded)" },
    { "key": "adidasBrandId",    "value": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbc", "type": "string", "description": "Adidas (seeded)" },
    { "key": "productTypeId",    "value": "11111111-1111-1111-1111-111111111111", "type": "string", "description": "Fashion (seeded)" },
    { "key": "colorAttrId",      "value": "cccccccc-cccc-cccc-cccc-000000000001", "type": "string", "description": "Color attr (seeded, Enum)" },
    { "key": "sizeAttrId",       "value": "cccccccc-cccc-cccc-cccc-000000000002", "type": "string", "description": "Size attr (seeded, Enum)" },
    { "key": "productId",        "value": "c67d6323-e8b1-4bdf-9a75-b0d0d2e7e914", "type": "string", "description": "Adidas Stan Smith (seeded)" },
    { "key": "productEtag",      "value": "", "type": "string", "description": "Auto-captured from GET /products/:id ETag header" },
    { "key": "newCategoryId",    "value": "", "type": "string" },
    { "key": "newBrandId",       "value": "", "type": "string" },
    { "key": "newAttrId",        "value": "", "type": "string" },
    { "key": "newProductTypeId", "value": "", "type": "string" },
    { "key": "newProductId",     "value": "", "type": "string" },
    { "key": "newImageId",       "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/categories?pageIndex=0&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["categories"],
              "query": [
                { "key": "pageIndex", "value": "0" },
                { "key": "pageSize",  "value": "10" },
                { "key": "search",    "value": "", "disabled": true },
                { "key": "parentId",  "value": "", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["categories","{{categoryId}}"] }
          },
          "response": []
        },
        {
          "name": "Create Category",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('newCategoryId', pm.response.json().id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Accessories\",\n  \"slug\": \"accessories\",\n  \"parentId\": null\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          },
          "response": []
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Accessories Updated\",\n  \"slug\": \"accessories-updated\",\n  \"parentId\": null\n}" },
            "url": { "raw": "{{baseUrl}}/categories/{{newCategoryId}}", "host": ["{{baseUrl}}"], "path": ["categories","{{newCategoryId}}"] }
          },
          "response": []
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/categories/{{newCategoryId}}", "host": ["{{baseUrl}}"], "path": ["categories","{{newCategoryId}}"] }
          },
          "response": []
        },
        {
          "name": "Delete Category in-use → 422",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["categories","{{categoryId}}"] },
            "description": "Expects 422 BusinessRuleException with `payload.productsUsing`."
          },
          "response": []
        },
        {
          "name": "Get Category – 404",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["categories","00000000-0000-0000-0000-000000000000"] }
          },
          "response": []
        }
      ]
    },
