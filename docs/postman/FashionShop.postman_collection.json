    {
      "name": "Products",
      "item": [
        {
          "name": "List Products (default — newest first)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?pageIndex=0&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "pageIndex",     "value": "0" },
                { "key": "pageSize",      "value": "10" },
                { "key": "search",        "value": "",  "disabled": true },
                { "key": "categoryId",    "value": "",  "disabled": true },
                { "key": "brandId",       "value": "",  "disabled": true },
                { "key": "productTypeId", "value": "",  "disabled": true },
                { "key": "status",        "value": "",  "disabled": true },
                { "key": "minPrice",      "value": "",  "disabled": true },
                { "key": "maxPrice",      "value": "",  "disabled": true },
                { "key": "sort",          "value": "Newest", "disabled": true }
              ]
            },
            "description": "sort values: Newest | NameAsc | NameDesc | PriceAsc | PriceDesc\nstatus values: Draft | Active | Inactive\npageSize capped at 100 server-side."
          },
          "response": []
        },
        {
          "name": "List Products – PriceAsc + Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?sort=PriceAsc&minPrice=50&maxPrice=200",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "sort",     "value": "PriceAsc" },
                { "key": "minPrice", "value": "50" },
                { "key": "maxPrice", "value": "200" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Products – Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?search=nike&sort=NameAsc",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "search", "value": "nike" },
                { "key": "sort",   "value": "NameAsc" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Products – Filter by Brand",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?brandId={{brandId}}&sort=Newest",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "brandId", "value": "{{brandId}}" },
                { "key": "sort",    "value": "Newest" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product by ID (captures ETag)",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 200) {",
              "  var etag = pm.response.headers.get('ETag');",
              "  if (etag) { pm.collectionVariables.set('productEtag', etag); console.log('ETag:', etag); }",
              "  pm.collectionVariables.set('productId', pm.response.json().product.id);",
              "}"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] },
            "description": "Response includes:\n- ETag header → captured into {{productEtag}}\n- rowVersion (uint, same value as ETag)\n- createdAt, lastModifiedAt (ISO 8601)\n- attributes[].dataType (String|Number|Boolean|Date|Enum)"
          },
          "response": []
        },
        {
          "name": "Create Product",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('newProductId', pm.response.json().id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"PUMA-RS-X-BLK-41\",\n  \"name\": \"Puma RS-X Black 41\",\n  \"slug\": \"puma-rs-x-black-41\",\n  \"description\": \"Puma RS-X retro-runner in black.\",\n  \"price\": 89.99,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"productTypeId\": \"{{productTypeId}}\",\n  \"status\": \"Draft\",\n  \"attributes\": [\n    { \"attributeDefinitionId\": \"{{colorAttrId}}\", \"value\": \"Black\" },\n    { \"attributeDefinitionId\": \"{{sizeAttrId}}\",  \"value\": \"41\" }\n  ],\n  \"images\": [\n    { \"url\": \"https://example.com/img/puma-rs-x.jpg\", \"alt\": \"Puma RS-X\", \"displayOrder\": 1, \"isPrimary\": true }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
          },
          "response": []
        },
        {
          "name": "Create Product – Error: missing required attrs (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"sku\": \"BAD-SKU-001\",\n  \"name\": \"Bad Product\",\n  \"slug\": \"bad-product\",\n  \"price\": 10.00,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"productTypeId\": \"{{productTypeId}}\",\n  \"status\": \"Draft\",\n  \"attributes\": []\n}" },
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
            "description": "Expects 400: color is required; size is required."
          },
          "response": []
        },
        {
          "name": "Create Product – Error: invalid enum value (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"sku\": \"BAD-SKU-002\",\n  \"name\": \"Bad Product 2\",\n  \"slug\": \"bad-product-2\",\n  \"price\": 10.00,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"productTypeId\": \"{{productTypeId}}\",\n  \"status\": \"Draft\",\n  \"attributes\": [\n    { \"attributeDefinitionId\": \"{{colorAttrId}}\", \"value\": \"Purple\" },\n    { \"attributeDefinitionId\": \"{{sizeAttrId}}\",  \"value\": \"42\" }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
            "description": "Expects 400: 'Purple' not in allowed [Black, White, Red, Blue]."
          },
          "response": []
        },
        {
          "name": "Create Product – Error: FluentValidation (400 with errors dict)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"sku\": \"\",\n  \"name\": \"\",\n  \"slug\": \"Invalid Slug!\",\n  \"price\": -5,\n  \"categoryId\": \"00000000-0000-0000-0000-000000000000\",\n  \"brandId\": \"00000000-0000-0000-0000-000000000000\",\n  \"productTypeId\": \"11111111-1111-1111-1111-111111111111\",\n  \"status\": \"Draft\",\n  \"attributes\": []\n}" },
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
            "description": "Expects 400 with errors.Sku, errors.Name, errors.Slug, errors.Price, etc."
          },
          "response": []
        },
        {
          "name": "Update Product – correct ETag (200)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "If-Match", "value": "{{productEtag}}", "description": "Run GET first to capture ETag" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Adidas Stan Smith White 40 – Limited Ed.\",\n  \"slug\": \"adidas-stan-smith-white-40\",\n  \"description\": \"Limited edition Adidas Stan Smith.\",\n  \"price\": 119.00,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{adidasBrandId}}\",\n  \"status\": \"Active\",\n  \"attributes\": [\n    { \"attributeDefinitionId\": \"{{colorAttrId}}\", \"value\": \"White\" },\n    { \"attributeDefinitionId\": \"{{sizeAttrId}}\",  \"value\": \"40\" }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] }
          },
          "response": []
        },
        {
          "name": "Update Product – STALE ETag (409 Conflict)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "If-Match", "value": "\"1\"", "description": "Deliberately stale xmin" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Stale update\",\n  \"slug\": \"adidas-stan-smith-white-40\",\n  \"price\": 50.00,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{adidasBrandId}}\",\n  \"status\": \"Active\",\n  \"attributes\": [\n    { \"attributeDefinitionId\": \"{{colorAttrId}}\", \"value\": \"White\" },\n    { \"attributeDefinitionId\": \"{{sizeAttrId}}\",  \"value\": \"40\" }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] },
            "description": "Expects 409 Conflict:\n{\n  \"title\": \"Concurrency conflict\",\n  \"status\": 409,\n  \"detail\": \"The resource was modified by another process. Reload and try again.\"\n}"
          },
          "response": []
        },
        {
          "name": "Update Product – no ETag (bypasses concurrency)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Adidas Stan Smith White 40\",\n  \"slug\": \"adidas-stan-smith-white-40\",\n  \"price\": 99.00,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{adidasBrandId}}\",\n  \"status\": \"Active\",\n  \"attributes\": [\n    { \"attributeDefinitionId\": \"{{colorAttrId}}\", \"value\": \"White\" },\n    { \"attributeDefinitionId\": \"{{sizeAttrId}}\",  \"value\": \"40\" }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] }
          },
          "response": []
        },
        {
          "name": "PATCH Product Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Inactive\"\n}" },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}/status", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}","status"] },
            "description": "Lightweight status change without full product payload.\nstatus: Draft | Active | Inactive"
          },
          "response": []
        },
        {
          "name": "Upsert Product Attribute",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"attributeDefinitionId\": \"{{colorAttrId}}\",\n  \"value\": \"Black\"\n}" },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}/attributes", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}","attributes"] },
            "description": "Adds a new attribute or updates value if already exists.\nValue is validated against AttributeDefinition.DataType and AllowedValues."
          },
          "response": []
        },
        {
          "name": "Remove Product Attribute",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/attributes/{{sizeAttrId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products","{{productId}}","attributes","{{sizeAttrId}}"]
            },
            "description": "Returns 400 if the attribute is required for the ProductType."
          },
          "response": []
        },
        {
          "name": "Upload Product Image (multipart)",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 201) {",
              "  var json = pm.response.json();",
              "  pm.collectionVariables.set('newImageId', json.image.id);",
              "  console.log('imageId:', json.image.id, 'url:', json.image.url);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file",         "type": "file",  "src": [], "description": "Select a jpg/png/webp ≤ 5 MB" },
                { "key": "alt",          "type": "text",  "value": "Product photo" },
                { "key": "displayOrder", "type": "text",  "value": "1" },
                { "key": "isPrimary",    "type": "text",  "value": "true" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/products/{{newProductId}}/images", "host": ["{{baseUrl}}"], "path": ["products","{{newProductId}}","images"] },
            "description": "Multipart upload. Saves to /uploads/products/{id}/.\nStored URL served as static file via UseStaticFiles.\nAccepted: image/jpeg, image/png, image/webp — max 5 MB."
          },
          "response": []
        },
        {
          "name": "Delete Product Image",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/products/{{newProductId}}/images/{{newImageId}}", "host": ["{{baseUrl}}"], "path": ["products","{{newProductId}}","images","{{newImageId}}"] },
            "description": "Also deletes the physical file from disk. Run Upload first."
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/products/{{newProductId}}", "host": ["{{baseUrl}}"], "path": ["products","{{newProductId}}"] },
            "description": "Soft-delete. Following GET returns 404."
          },
          "response": []
        },
        {
          "name": "Get Deleted Product – 404",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products/{{newProductId}}", "host": ["{{baseUrl}}"], "path": ["products","{{newProductId}}"] }
          },
          "response": []
        },
        {
          "name": "Get Product – 404 (non-existent)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["products","00000000-0000-0000-0000-000000000000"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "_Guided Demo Flow",
      "description": "Run in order — demonstrates full E2E flow against seeded data.",
      "item": [
        {
          "name": "1. GET Fashion ProductType (verify seed)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/product-types/{{productTypeId}}", "host": ["{{baseUrl}}"], "path": ["product-types","{{productTypeId}}"] }
          },
          "response": []
        },
        {
          "name": "2. GET All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
          },
          "response": []
        },
        {
          "name": "3. GET Adidas (captures ETag)",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "var etag = pm.response.headers.get('ETag');",
              "if (etag) { pm.collectionVariables.set('productEtag', etag); console.log('ETag:', etag); }"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] }
          },
          "response": []
        },
        {
          "name": "4. PUT correct ETag → 200 OK",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "If-Match", "value": "{{productEtag}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Adidas Stan Smith White 40 (demo v2)\",\n  \"slug\": \"adidas-stan-smith-white-40\",\n  \"description\": \"Updated via demo flow.\",\n  \"price\": 105.00,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{adidasBrandId}}\",\n  \"status\": \"Active\",\n  \"attributes\": [\n    { \"attributeDefinitionId\": \"{{colorAttrId}}\", \"value\": \"White\" },\n    { \"attributeDefinitionId\": \"{{sizeAttrId}}\",  \"value\": \"40\" }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] }
          },
          "response": []
        },
        {
          "name": "5. PUT same ETag → 409 Conflict",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "If-Match", "value": "{{productEtag}}", "description": "Stale — xmin was bumped in step 4" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Conflict attempt\",\n  \"slug\": \"adidas-stan-smith-white-40\",\n  \"price\": 50.00,\n  \"categoryId\": \"{{categoryId}}\",\n  \"brandId\": \"{{adidasBrandId}}\",\n  \"status\": \"Active\",\n  \"attributes\": [\n    { \"attributeDefinitionId\": \"{{colorAttrId}}\", \"value\": \"White\" },\n    { \"attributeDefinitionId\": \"{{sizeAttrId}}\",  \"value\": \"40\" }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}"] }
          },
          "response": []
        },
        {
          "name": "6. PATCH status → Inactive",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Inactive\"\n}" },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}/status", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}","status"] }
          },
          "response": []
        },
        {
          "name": "7. Upsert attribute – change color to Red",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"attributeDefinitionId\": \"{{colorAttrId}}\",\n  \"value\": \"Red\"\n}" },
            "url": { "raw": "{{baseUrl}}/products/{{productId}}/attributes", "host": ["{{baseUrl}}"], "path": ["products","{{productId}}","attributes"] }
          },
          "response": []
        },
        {
          "name": "8. CREATE new product",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 201) {",
