        {
          "name": "10. DELETE new product (soft-delete)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/products/{{newProductId}}", "host": ["{{baseUrl}}"], "path": ["products","{{newProductId}}"] }
